  "main": "index.js",
  "scripts": {
    "start:admin": "wp-scripts start --config webpack.admin.js",
    "build:admin": "wp-scripts build --config webpack.admin.js",
    "start:blocks": "wp-scripts start",
    "build:blocks": "wp-scripts build",
    "build": "npm run build:blocks && npm run build:admin",
    "clean": "rm -rf build *.zip node_modules/.cache",
    "prezip": "npm run clean && npm run build",
    "zip": "zip -r igk-plugin.zip . -x 'node_modules/*' 'src/*' '.git/*' '*.zip' 'webpack*.js' 'tailwind.config.js' 'postcss.config.js' 'babel.config.js' '.env*' '*.log' 'package-lock.json' 'package.json' 'tsconfig.json'"
  },
