  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@wordpress/scripts": "^32.0.0",
    "autoprefixer": "^10.5.0",
    "css-loader": "^7.1.4",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19"
  }
