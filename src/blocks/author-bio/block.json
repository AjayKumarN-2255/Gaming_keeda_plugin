{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "igk/author-bio",
    "title": "Author Bio",
    "category": "text",
    "icon": "admin-users",
    "description": "Displays author bio information for iGamingKeeda",
    "keywords": [
        "author",
        "bio",
        "profile"
    ],
    "version": "1.0.0",
    "textdomain": "igk",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./index.css",
    "supports": {
        "html": false,
        "show_in_graphql": true
    },
    "attributes": {
        "name": {
            "type": "string",
            "default": "John Doe"
        },
        "role": {
            "type": "string",
            "default": "Author"
        },
        "desc": {
            "type": "string",
            "default": ""
        },
        "imgURL": {
            "type": "string",
            "default": ""
        },
        "updated": {
            "type": "string"
        }
    }
}